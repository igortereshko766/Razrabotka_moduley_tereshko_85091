import sys
from PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget,
                             QVBoxLayout, QHBoxLayout, QPushButton,
                             QLineEdit, QLabel, QListWidget, QMessageBox,
                             QAction, QTabWidget, QInputDialog, QStatusBar)
from PyQt5.QtCore import Qt
from database import Database  # Импорт модуля базы данных


class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.db = Database()  # Подключаем базу данных
        self.initUI()
        self.update_list()

    def initUI(self):
        # Настройка главного окна
        self.setWindowTitle("Менеджер заметок v3.0")
        self.setMinimumSize(600, 450)
        self.setGeometry(100, 100, 750, 550)

        # Меню
        self.create_menu()

        # Статус-бар
        self.status_bar = QStatusBar()
        self.setStatusBar(self.status_bar)
        self.update_status()

        # Вкладки
        tabs = QTabWidget()

        tab_add = self.create_add_tab()
        tabs.addTab(tab_add, "➕ Добавить")

        tab_list = self.create_list_tab()
        tabs.addTab(tab_list, "📋 Список")

        tab_search = self.create_search_tab()
        tabs.addTab(tab_search, "🔍 Поиск")

        self.setCentralWidget(tabs)
        self.apply_styles()

    def create_menu(self):
        """Создание меню"""
        menu_bar = self.menuBar()

        # Файл
        file_menu = menu_bar.addMenu("📁 Файл")

        new_action = QAction("Новая заметка", self)
        new_action.setShortcut("Ctrl+N")
        new_action.triggered.connect(self.new_note)
        file_menu.addAction(new_action)

        file_menu.addSeparator()

        exit_action = QAction("Выход", self)
        exit_action.setShortcut("Ctrl+Q")
        exit_action.triggered.connect(self.close)
        file_menu.addAction(exit_action)

        # Правка
        edit_menu = menu_bar.addMenu("✏ Правка")

        rename_action = QAction("Переименовать", self)
        rename_action.setShortcut("F2")
        rename_action.triggered.connect(self.rename_note)
        edit_menu.addAction(rename_action)

        delete_action = QAction("Удалить", self)
        delete_action.setShortcut("Delete")
        delete_action.triggered.connect(self.delete_note)
        edit_menu.addAction(delete_action)

        edit_menu.addSeparator()

        clear_action = QAction("Очистить всё", self)
        clear_action.triggered.connect(self.clear_all)
        edit_menu.addAction(clear_action)

        # Справка
        help_menu = menu_bar.addMenu("❓ Справка")

        about_action = QAction("О программе", self)
        about_action.triggered.connect(self.show_about)
        help_menu.addAction(about_action)

    def create_add_tab(self):
        """Вкладка добавления"""
        tab = QWidget()
        layout = QVBoxLayout()
        layout.setSpacing(15)
        layout.setContentsMargins(25, 25, 25, 25)

        header = QLabel("Новая заметка")
        header.setAlignment(Qt.AlignCenter)
        header.setStyleSheet("font-size: 20px; font-weight: bold; color: #2c3e50;")
        layout.addWidget(header)

        self.text_input = QLineEdit()
        self.text_input.setPlaceholderText("Введите текст заметки...")
        self.text_input.setMinimumHeight(45)
        self.text_input.returnPressed.connect(self.add_note)
        layout.addWidget(self.text_input)

        btn_layout = QHBoxLayout()

        add_btn = QPushButton("💾 Сохранить в БД")
        add_btn.setMinimumHeight(45)
        add_btn.clicked.connect(self.add_note)
        add_btn.setStyleSheet(self.btn_style("#2ecc71", "#27ae60"))
        btn_layout.addWidget(add_btn)

        clear_btn = QPushButton("✕ Очистить")
        clear_btn.setMinimumHeight(45)
        clear_btn.clicked.connect(lambda: self.text_input.clear())
        clear_btn.setStyleSheet(self.btn_style("#95a5a6", "#7f8c8d"))
        btn_layout.addWidget(clear_btn)

        layout.addLayout(btn_layout)

        self.add_info = QLabel("")
        self.add_info.setAlignment(Qt.AlignCenter)
        layout.addWidget(self.add_info)

        layout.addStretch()
        tab.setLayout(layout)
        return tab

    def create_list_tab(self):
        """Вкладка списка"""
        tab = QWidget()
        layout = QVBoxLayout()
        layout.setSpacing(10)
        layout.setContentsMargins(25, 25, 25, 25)

        header = QLabel("Все заметки")
        header.setAlignment(Qt.AlignCenter)
        header.setStyleSheet("font-size: 20px; font-weight: bold; color: #2c3e50;")
        layout.addWidget(header)

        self.counter_label = QLabel("")
        self.counter_label.setAlignment(Qt.AlignCenter)
        layout.addWidget(self.counter_label)

        self.list_widget = QListWidget()
        self.list_widget.setAlternatingRowColors(True)
        layout.addWidget(self.list_widget)

        btn_layout = QHBoxLayout()

        delete_btn = QPushButton("🗑 Удалить")
        delete_btn.setMinimumHeight(40)
        delete_btn.clicked.connect(self.delete_note)
        delete_btn.setStyleSheet(self.btn_style("#e74c3c", "#c0392b"))
        btn_layout.addWidget(delete_btn)

        rename_btn = QPushButton("✎ Изменить")
        rename_btn.setMinimumHeight(40)
        rename_btn.clicked.connect(self.rename_note)
        rename_btn.setStyleSheet(self.btn_style("#f39c12", "#e67e22"))
        btn_layout.addWidget(rename_btn)

        layout.addLayout(btn_layout)
        tab.setLayout(layout)
        return tab

    def create_search_tab(self):
        """Вкладка поиска"""
        tab = QWidget()
        layout = QVBoxLayout()
        layout.setSpacing(15)
        layout.setContentsMargins(25, 25, 25, 25)

        header = QLabel("Поиск по заметкам")
        header.setAlignment(Qt.AlignCenter)
        header.setStyleSheet("font-size: 20px; font-weight: bold; color: #2c3e50;")
        layout.addWidget(header)

        self.search_input = QLineEdit()
        self.search_input.setPlaceholderText("🔍 Введите текст для поиска...")
        self.search_input.setMinimumHeight(40)
        self.search_input.textChanged.connect(self.search_notes)
        layout.addWidget(self.search_input)

        self.search_list = QListWidget()
        self.search_list.setAlternatingRowColors(True)
        layout.addWidget(self.search_list)

        tab.setLayout(layout)
        return tab

    # ========== МЕТОДЫ РАБОТЫ С ДАННЫМИ ==========

    def add_note(self):
        """Добавление заметки в БД"""
        text = self.text_input.text().strip()
        if not text:
            QMessageBox.warning(self, "Ошибка", "Введите текст!")
            return

        self.db.add_note(text)
        self.text_input.clear()
        self.update_list()
        self.add_info.setText(f"✅ Добавлено! Всего: {self.db.get_count()}")
        self.update_status()

    def delete_note(self):
        """Удаление заметки из БД"""
        row = self.list_widget.currentRow()
        if row < 0:
            QMessageBox.warning(self, "Ошибка", "Выберите заметку!")
            return

        notes = self.db.get_all_notes()
        note_id = notes[row][0]

        reply = QMessageBox.question(self, "Подтверждение",
                                     "Удалить заметку?",
                                     QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.db.delete_note(note_id)
            self.update_list()
            self.update_status()

    def rename_note(self):
        """Изменение заметки"""
        row = self.list_widget.currentRow()
        if row < 0:
            QMessageBox.warning(self, "Ошибка", "Выберите заметку!")
            return

        notes = self.db.get_all_notes()
        note_id = notes[row][0]
        old_text = notes[row][1]

        new_text, ok = QInputDialog.getText(
            self, "Изменить", "Новый текст:",
            QLineEdit.Normal, old_text
        )

        if ok and new_text.strip():
            self.db.update_note(note_id, new_text.strip())
            self.update_list()
            self.update_status()

    def clear_all(self):
        """Удаление всех заметок"""
        count = self.db.get_count()
        if count == 0:
            QMessageBox.information(self, "Информация", "Нет заметок.")
            return

        reply = QMessageBox.question(
            self, "Подтверждение",
            f"Удалить ВСЕ заметки ({count} шт.)?",
            QMessageBox.Yes | QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            self.db.clear_all()
            self.update_list()
            self.update_status()

    def search_notes(self):
        """Поиск заметок"""
        query = self.search_input.text().strip()
        self.search_list.clear()

        if query:
            results = self.db.search_notes(query)
            for note in results:
                self.search_list.addItem(f"[{note[2]}] {note[1]}")

    def new_note(self):
        """Переход на вкладку добавления"""
        self.centralWidget().setCurrentIndex(0)
        self.text_input.setFocus()

    def show_about(self):
        """О программе"""
        QMessageBox.about(
            self, "О программе",
            "📝 Менеджер заметок v3.0\n\n"
            "Хранение данных: SQLite\n"
            "Графический интерфейс: PyQt5\n\n"
            f"Заметок в базе: {self.db.get_count()}"
        )

    # ========== ВСПОМОГАТЕЛЬНЫЕ МЕТОДЫ ==========

    def update_list(self):
        """Обновление списка заметок"""
        self.list_widget.clear()
        notes = self.db.get_all_notes()
        for note in notes:
            self.list_widget.addItem(f"[{note[2]}] {note[1]}")
        self.counter_label.setText(f"📊 Всего заметок в БД: {len(notes)}")

    def update_status(self):
        """Обновление статус-бара"""
        self.status_bar.showMessage(f"Записей в базе данных: {self.db.get_count()}")

    def btn_style(self, color, hover):
        """Стиль кнопок"""
        return f"""
            QPushButton {{
                background-color: {color};
                color: white;
                border: none;
                border-radius: 8px;
                font-size: 14px;
                font-weight: bold;
            }}
            QPushButton:hover {{
                background-color: {hover};
            }}
        """

    def apply_styles(self):
        """Общие стили"""
        self.setStyleSheet("""
            QMainWindow { background-color: #f5f6fa; }
            QListWidget {
                border: 2px solid #bdc3c7;
                border-radius: 8px;
                font-size: 13px;
            }
            QListWidget::item { padding: 8px; }
            QListWidget::item:selected {
                background-color: #3498db;
                color: white;
            }
            QLineEdit {
                border: 2px solid #bdc3c7;
                border-radius: 8px;
                padding: 8px;
                font-size: 14px;
            }
            QLineEdit:focus { border-color: #3498db; }
        """)

    def closeEvent(self, event):
        """Закрытие приложения"""
        self.db.close()
        event.accept()


def main():
    app = QApplication(sys.argv)
    window = MainWindow()
    window.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()
